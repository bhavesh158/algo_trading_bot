# ============================================================
# Algo Trading Bot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is git-ignored and never committed.
# ============================================================

# --- Angel One Credentials ---
# Get your API key from: https://smartapi.angelone.in/
BROKER_API_KEY=
BROKER_CLIENT_ID=
BROKER_PASSWORD=
BROKER_TOTP_SECRET=

# --- Zerodha Credentials (if using Zerodha instead) ---
# BROKER_API_KEY=
# BROKER_API_SECRET=
# BROKER_ACCESS_TOKEN=

# --- Config Overrides (optional) ---
# Override any config value using ALGO_TRADING__section__key format.
# Examples:
# ALGO_TRADING__account__initial_capital=200000
# ALGO_TRADING__risk__max_risk_per_trade_pct=0.5
# ALGO_TRADING__system__log_level=DEBUG
